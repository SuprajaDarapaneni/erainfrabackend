# Port selection (Render auto-populates this, but defaults to 3000)
PORT=3000

# MongoDB Connection URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/era-infra

# Cloudinary Credentials
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Secure Administrator Portal Credentials
ADMIN_EMAIL=admin@erainfra.com
ADMIN_PASSWORD=admin123

